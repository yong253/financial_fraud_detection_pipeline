# ============================================================
#  .env.example  —  복사해서 .env 로 사용 (`cp .env.example .env`)
#  .env 는 절대 커밋하지 않는다 (.gitignore 포함됨)
# ============================================================

# ===== GCP (★ 학습 후 입력. 그 전에는 아래 로컬 대체재 사용) =====
GCP_PROJECT_ID=
GCS_BUCKET_BRONZE=
GCS_BUCKET_SILVER=
GCS_BUCKET_GOLD=
BQ_DATASET_SILVER=fraud_silver
BQ_DATASET_GOLD=fraud_gold
GCP_CREDENTIALS_PATH=./credentials/service_account.json

# ===== 스토리지 추상화 (로컬 우선, 코드엔 이 변수만 사용) =====
#  로컬:        ./datalake      (Bronze/Silver/Gold 하위 디렉토리)
#  GCP 전환 시: gs://{bucket}   로만 교체하면 코드 수정 불필요
STORAGE_BASE_PATH=./datalake
BRONZE_PATH=./datalake/bronze
SILVER_PATH=./datalake/silver

# ===== Silver 배치 설정 =====
# step → tx_timestamp 변환 기준 시각 (PaySim step=1의 절대 시각)
STEP_EPOCH=2016-01-01 00:00:00

# ===== Kafka (3-broker 클러스터) =====
# 호스트(로컬 Producer)에서 접속: 브로커 3개 모두 등록 → 1대 장애에도 연결
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093,localhost:9094
# 컨테이너 내부 실행 전환 시: kafka1:29092,kafka2:29092,kafka3:29092
KAFKA_TOPIC=transactions
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION=3
# --- 멱등 Producer 정합성 (producer.py 코드에서 기본값으로 강제) ---
#   enable.idempotence=true (→ acks=all, retries 무한급, max.in.flight<=5 자동)
#   acks=all / compression.type=lz4 / key=nameOrig(계좌별 순서)
KAFKA_MIN_INSYNC_REPLICAS=2

# ===== 데이터셋 =====
RAW_CSV_PATH=./data/raw/Synthetic_Financial_datasets_log.csv
# Producer 전송 속도 (초당 메시지 수, 0=제한없음)
PRODUCER_RATE_PER_SEC=1000
